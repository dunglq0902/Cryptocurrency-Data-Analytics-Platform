# .env.example
# Copy to .env and fill in your actual values before running.
# NEVER commit .env to version control.

# ─────────────────────────────────────────────
# Binance API
# ─────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ─────────────────────────────────────────────
# Kafka
# ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ─────────────────────────────────────────────
# Spark / HDFS
# ─────────────────────────────────────────────
SPARK_MASTER=spark://localhost:7077
HDFS_NAMENODE=hdfs://localhost:8020
DELTA_BASE_PATH=hdfs://localhost:8020/lakehouse
SPARK_CHECKPOINT_BASE=hdfs://localhost:8020/checkpoints

# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
MONGO_URI=mongodb://root:changeme@localhost:27017
MONGO_DB=crypto_analytics

# ─────────────────────────────────────────────
# Telegram Notifications
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─────────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=alerts@crypto-analytics.io

# ─────────────────────────────────────────────
# Alert Engine API
# ─────────────────────────────────────────────
NOTIFICATION_SVC=http://localhost:8001
ALERT_API_PORT=8000

# ─────────────────────────────────────────────
# Airflow
# ─────────────────────────────────────────────
AIRFLOW_FERNET_KEY=changeme-fernet-key-must-be-32-chars!
AIRFLOW_WEBSERVER_SECRET_KEY=changeme-webserver-secret

# ─────────────────────────────────────────────
# Kubernetes (for production deployment)
# ─────────────────────────────────────────────
K8S_NAMESPACE=spark-system
SPARK_K8S_IMAGE=crypto-analytics/spark:latest
CONTAINER_REGISTRY=your-registry.example.com
